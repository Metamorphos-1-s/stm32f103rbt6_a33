  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D E:\VScode_STM32_Project\stm32f103rbt6_a33\build\Release\cmake\stm32cubemx && E:\ST\STM32CubeCLT_1.18.0\CMake\bin\cmake.exe --regenerate-during-build -SE:\VScode_STM32_Project\stm32f103rbt6_a33 -BE:\VScode_STM32_Project\stm32f103rbt6_a33\build\Release"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build cmake/stm32cubemx/rebuild_cache: phony cmake/stm32cubemx/CMakeFiles/rebuild_cache.util

