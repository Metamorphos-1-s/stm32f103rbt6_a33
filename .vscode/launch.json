{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: Launch ST-Link GDB Server",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build Debug",
            "deviceName": "STM32F103RBT6",
            "deviceCore": "Cortex-M3",
            "gdb": "E:/ST/STM32CubeCLT_1.18.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            "serverExe": "E:/ST/STM32CubeCLT_1.18.0/STLink-gdb-server/bin/ST-LINK_gdbserver.exe",
            "serverCubeProgPath": "E:/ST/STM32CubeCLT_1.18.0/STM32CubeProgrammer/bin",
            "serverInterface": "SWD",
            "runEntry": "main",
            "imagesAndSymbols": [
                {
                    "imageFileName": "${workspaceFolder}/build/Debug/stm32f103rbt6_a33.elf"
                }
            ]
        }
    ]
}
